---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import SectionHeader from "../components/SectionHeader.astro";

const districts = (await getCollection("districts")).sort(
  (a, b) => a.data.order - b.data.order
);

const events = (await getCollection("events"))
  .filter((e) => e.data.featured)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);

const attractions = (await getCollection("attractions"))
  .filter((a) => a.data.featured)
  .slice(0, 3);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-PH", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---

<Layout title="Iloilo Province | Tourism — Fun. Foodie. Friendly.">
  <Header transparent />

  <section class="hero">
    <div class="hero__bg">
      <img
        src="/images/hero.jpg"
        alt="Iloilo Province"
        class="hero__img"
        fetchpriority="high"
      />
      <div class="hero__overlay"></div>
    </div>

    <div class="hero__content container">
      <div class="hero__badge">Welcome to Iloilo Province</div>
      <h1 class="hero__title">
        Fun.<br /><em>Foodie.</em><br />Friendly.
      </h1>
      <p class="hero__sub">
        Discover five vibrant districts, a world-class food scene,<br
          class="br-desktop"
        /> and the warmest people in the Philippines.
      </p>
      <div class="hero__ctas">
        <a href="/districts" class="btn btn--primary">Explore Districts</a>
        <a href="/events" class="btn btn--ghost">Upcoming Events</a>
      </div>
    </div>

    <div class="hero__scroll">
      <span>Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <section class="section container">
    <SectionHeader
      label="Five Districts"
      title="Where would you like to go?"
      subtitle="From the vibrant city to UNESCO heritage towns — each district has its own soul."
      viewAllHref="/districts"
      viewAllLabel="All districts"
    />

    <div class="district-grid">
      {
        districts.map((d) => (
          <a href={`/districts/${d.slug}`} class="district-card">
            <div class="district-card__img-wrap">
              <img
                src={d.data.heroImage}
                alt={d.data.name}
                class="district-card__img"
                loading="lazy"
              />
              <div class="district-card__overlay" />
            </div>
            <div class="district-card__body">
              <span class="district-card__tag">{d.data.tagline}</span>
              <h3 class="district-card__name">{d.data.name}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- FEATURED EVENTS -->
  {
    events.length > 0 && (
      <section class="section container">
        <SectionHeader
          label="Events"
          title="What's happening"
          viewAllHref="/events"
          viewAllLabel="All events"
        />
        <div class="card-grid card-grid--3">
          {events.map((e) => (
            <Card
              title={e.data.title}
              description={e.data.description}
              image={e.data.image}
              date={formatDate(e.data.date)}
              tag={e.data.district}
              href={`/events#${e.slug}`}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- FEATURED ATTRACTIONS -->
  {
    attractions.length > 0 && (
      <section class="section container">
        <SectionHeader
          label="Attractions"
          title="Places to see"
          viewAllHref="/attractions"
          viewAllLabel="All attractions"
        />
        <div class="card-grid card-grid--3">
          {attractions.map((a) => (
            <Card
              title={a.data.name}
              description={a.data.description}
              image={a.data.image}
              tag={a.data.district}
              href="/attractions"
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- TASTE OF ILOILO banner -->
  <section class="taste-banner">
    <div class="taste-banner__inner container">
      <div class="taste-banner__text">
        <span class="taste-banner__label">Food Capital of the Philippines</span>
        <h2 class="taste-banner__title">
          Taste the<br /><em>Iloilo</em> difference
        </h2>
        <p>
          From La Paz Batchoy to fresh seafood by the strait — Ilonggo cuisine
          is a love language spoken through every bowl, plate, and bite.
        </p>
        <a href="/food" class="btn btn--outline-light">Discover Iloilo Food</a>
      </div>
      <div class="taste-banner__img-wrap">
        <img src="/images/food/batchoy.jpg" alt="La Paz Batchoy" loading="lazy" />
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform 0.1s linear;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 20, 16, 0.85) 0%,
      rgba(26, 20, 16, 0.3) 50%,
      transparent 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 2;
    padding-bottom: 5rem;
    color: white;
  }

  .hero__badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 9rem);
    font-weight: 400;
    line-height: 1.0;
    margin-bottom: 1.5rem;
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-terracotta);
  }

  .hero__sub {
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 2rem;
    max-width: 45ch;
  }

  .br-desktop {
    display: none;
  }
  @media (min-width: 768px) {
    .br-desktop { display: block; }
  }

  .hero__ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    z-index: 2;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent);
    animation: scrollLine 2s ease infinite;
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* BUTTONS */
  .btn {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    font-size: 0.87rem;
    font-weight: 600;
    transition: all 0.25s;
    letter-spacing: 0.02em;
  }

  .btn--primary {
    background: var(--color-terracotta);
    color: white;
  }
  .btn--primary:hover {
    background: #b5633e;
    transform: translateY(-2px);
  }

  .btn--ghost {
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(8px);
  }
  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .btn--outline-light {
    border: 1.5px solid rgba(255,255,255,0.5);
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    font-size: 0.87rem;
    font-weight: 600;
    transition: all 0.25s;
  }

  .btn--outline-light:hover {
    background: rgba(255,255,255,0.15);
  }

  /* SECTIONS */
  .section {
    padding: 5rem 0;
  }

  /* DISTRICT GRID */
  .district-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .district-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .district-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .district-card {
    position: relative;
    border-radius: var(--radius-card);
    overflow: hidden;
    aspect-ratio: 3/4;
    display: flex;
    align-items: flex-end;
    cursor: pointer;
  }

  .district-card__img-wrap {
    position: absolute;
    inset: 0;
  }

  .district-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .district-card:hover .district-card__img {
    transform: scale(1.08);
  }

  .district-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 20, 16, 0.8) 0%,
      rgba(26, 20, 16, 0.1) 60%,
      transparent 100%
    );
    transition: opacity 0.3s;
  }

  .district-card__body {
    position: relative;
    z-index: 1;
    padding: 1rem;
    color: white;
  }

  .district-card__tag {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.06em;
    margin-bottom: 0.25rem;
  }

  .district-card__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.2;
  }

  /* CARD GRID */
  .card-grid {
    display: grid;
    gap: 1.25rem;
  }

  .card-grid--3 {
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .card-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .card-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* TASTE BANNER */
  .taste-banner {
    background: var(--color-deep);
    margin: 4rem 0 0;
  }

  .taste-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .taste-banner__inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .taste-banner__text {
    color: white;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 40ch;
  }

  .taste-banner__label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-terracotta);
  }

  .taste-banner__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
  }

  .taste-banner__title em {
    font-style: italic;
    color: var(--color-terracotta);
  }

  .taste-banner__text p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
  }

  .taste-banner__img-wrap {
    width: 100%;
    max-width: 400px;
    border-radius: var(--radius-card);
    overflow: hidden;
    aspect-ratio: 4/3;
    flex-shrink: 0;
  }

  .taste-banner__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  // Subtle parallax on hero image
  const heroImg = document.querySelector(".hero__img") as HTMLImageElement;
  window.addEventListener("scroll", () => {
    if (heroImg) {
      heroImg.style.transform = `translateY(${window.scrollY * 0.3}px)`;
    }
  }, { passive: true });
</script>
