---
export const prerender = true;

import { formatDate } from "@/lib/utils/date";
import SectionHeader from "@/components/SectionHeader.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { SupabaseAPI } from "@/lib/api/Supabase";

const [districts, events, attractions] = await Promise.all([
  SupabaseAPI.districts.getAll(),
  SupabaseAPI.events.getFeatured(3),
  SupabaseAPI.attractions.getFeatured(3),
]);
---

<Layout title="Iloilo Province | Tourism — Fun. Foodie. Friendly.">
  <Header transparent />
  <section class="relative flex h-svh min-h-150 items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        data-hero-img
        src="/images/hero.jpg"
        alt="Iloilo Province"
        class="h-[110%] w-full object-cover object-center transition-transform duration-100 will-change-transform"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-linear-to-t from-deep/85 via-deep/30 to-transparent"></div>
    </div>

    <div class="section-container relative z-10 pb-20 text-white">
      <div
        class="mb-6 inline-flex rounded-full border border-white/25 bg-white/15 px-4 py-1.5 text-xs font-medium tracking-[0.06em] text-white/90 backdrop-blur-md"
      >
        Welcome to Iloilo Province
      </div>

      <h1 class="mb-6 font-display text-[clamp(3.5rem,12vw,9rem)] font-normal leading-none">
        Fun.<br />
        <em class="text-primary">Foodie.</em><br />
        Friendly.
      </h1>

      <p class="mb-8 max-w-[45ch] text-[clamp(0.9rem,2vw,1.1rem)] leading-[1.65] text-white/80">
        Discover five vibrant districts, a world-class food scene,<br class="hidden md:block" />
        and the warmest people in the Philippines.
      </p>

      <div class="flex flex-wrap gap-3">
        <a
          href="/districts"
          class="inline-flex rounded-full bg-primary px-6 py-3 text-[0.87rem] font-semibold tracking-[0.02em] text-foreground transition duration-200 hover:-translate-y-0.5 hover:bg-primary-dark"
        >
          Explore Districts
        </a>

        <a
          href="/events"
          class="inline-flex rounded-full border border-white/35 bg-white/15 px-6 py-3 text-[0.87rem] font-semibold tracking-[0.02em] text-white backdrop-blur-md transition duration-200 hover:bg-white/25"
        >
          Upcoming Events
        </a>
      </div>
    </div>

    <div
      class="absolute bottom-8 right-8 z-10 flex flex-col items-center gap-2 text-2xs font-medium uppercase tracking-widest text-white/60"
    >
      <span>Scroll</span>
      <div
        class="h-10 w-px origin-top bg-linear-to-b from-white/60 to-transparent animate-[scrollLine_2s_ease_infinite]"
      >
      </div>
    </div>
  </section>

  <section class="section-container min-h-svh flex flex-col justify-center items-center gap-16">
    <SectionHeader
      label="Five Districts"
      title="Where would you like to go?"
      subtitle="From the vibrant city to UNESCO heritage towns — each district has its own soul."
    />

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        districts.map((d) => (
          <a
            href={`/districts/${d.slug}`}
            class="group relative flex aspect-3/4 cursor-pointer overflow-hidden rounded-card"
          >
            <div class="absolute inset-0">
              <img
                src={d.hero_image}
                alt={d.name}
                class="h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-linear-to-t from-deep/80 via-deep/10 to-transparent transition-opacity duration-300" />
            </div>

            <div class="relative z-10 p-4 text-white">
              <h3 class="font-display text-[1.1rem] font-bold leading-[1.2]">{d.name}</h3>
              <span class="mb-1 block text-[0.68rem] font-medium tracking-[0.06em] text-white/70">
                {d.tagline}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {
    events.length > 0 && (
      <section class="py-20">
        <div class="section-container">
          <SectionHeader
            label="Events"
            title="What's happening"
            viewAllHref="/events"
            viewAllLabel="All events"
          />
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {events.map((e) => (
              <Card
                title={e.name}
                description={e.short_description}
                image={e.hero_image}
                date={formatDate(e.date)}
                tag={e.district_name}
                href={`/events/${e.slug}`}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    attractions.length > 0 && (
      <section class="py-20">
        <div class="section-container">
          <SectionHeader
            label="Attractions"
            title="Places to see"
            viewAllHref="/attractions"
            viewAllLabel="All attractions"
          />
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {attractions.map((a) => (
              <Card
                title={a.name}
                description={a.short_description}
                image={a.hero_image}
                tag={a.district_name}
                href={`/attractions/${a.slug}`}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="mt-16 bg-deep">
    <div class="section-container flex flex-col items-center gap-12 py-16 md:flex-row md:justify-between">
      <div class="flex max-w-[40ch] flex-col gap-4 text-white">
        <span class="text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-primary">
          Food Capital of the Philippines
        </span>
        <h2 class="font-display text-[clamp(2rem,6vw,3.5rem)] font-normal leading-[1.1]">
          Taste the<br />
          <em class="text-primary">Iloilo</em> difference
        </h2>
        <p class="text-[0.9rem] leading-[1.7] text-white/65">
          From La Paz Batchoy to fresh seafood by the strait — Ilonggo cuisine is a love language spoken
          through every bowl, plate, and bite.
        </p>
        <a
          href="/food"
          class="inline-flex w-fit rounded-full border border-white/50 px-6 py-3 text-[0.87rem] font-semibold tracking-[0.02em] text-white transition duration-200 hover:bg-white/15"
        >
          Discover Iloilo Food
        </a>
      </div>

      <div class="aspect-4/3 w-full max-w-100 shrink-0 overflow-hidden rounded-card">
        <img
          src="https://placehold.co/400x400?text=Placeholder"
          alt="La Paz Batchoy"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const heroImg = document.querySelector("[data-hero-img]");

  if (heroImg instanceof HTMLElement) {
    let current = 0;
    let target = 0;
    const speed = 0.12;

    const animate = () => {
      target = window.scrollY;
      current += (target - current) * speed;

      const y = current * 0.2;
      heroImg.style.transform = `translate3d(0, ${y}px, 0)`;

      requestAnimationFrame(animate);
    };

    requestAnimationFrame(animate);
  }
</script>
