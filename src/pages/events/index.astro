---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";
import { formatDate } from "@/lib/utils/date";
import { SupabaseAPI } from "../../lib/api/Supabase";

const [allEvents, districtFilters] = await Promise.all([
  SupabaseAPI.events.getAll(),
  SupabaseAPI.districts.getFilters(),
]);

const now = new Date();

const upcoming = allEvents.filter((e) => new Date(e.date) >= now);
const past = allEvents.filter((e) => new Date(e.date) < now);
---

<Layout title="Events | Iloilo Province Tourism">
  <Header />

  <main class="section-container px-4 pb-16 pt-32 md:px-6 lg:px-8">
    <SectionHeader
      label="Iloilo Events"
      title="What's on"
      subtitle="From grand festivals to intimate cultural tours — something's always happening in Iloilo."
    />

    <FilterTabs
      filters={districtFilters}
      activeFilter="all"
      paramName="district"
    />

    {
      upcoming.length > 0 ? (
        <div class="grid grid-cols-1 gap-8 min-h-100 md:grid-cols-2 lg:grid-cols-3">
          {upcoming.map((e) => (
            <div data-filter={e.district_slug}>
              <Card
                title={e.name}
                description={e.short_description}
                image={e.hero_image}
                date={formatDate(e.date)}
                tag={e.district_name}
                size="lg"
              />

              {e.venue && (
                <div class="flex flex-wrap items-center gap-2 px-1">
                  <span class="flex-1 text-[0.78rem] text-muted">
                    📍 {e.venue}
                  </span>

                  {e.tags?.map((tag) => (
                    <span class="rounded-full bg-primary/10 px-2 py-0.5 text-[0.7rem] font-semibold capitalize text-primary">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="py-16 text-center text-muted">
          <p>No upcoming events found.</p>
          <a href="/events" class="font-semibold text-primary">
            View all events
          </a>
        </div>
      )
    }

    {
      past.length > 0 && (
        <section class="mt-16 border-t border-deep/8 pt-12">
          <h2 class="mb-6 font-display text-2xl font-normal text-muted">
            Past Events
          </h2>

          <div class="grid grid-cols-1 gap-8 min-h-[300px] opacity-65 md:grid-cols-2 lg:grid-cols-3">
            {past.map((e) => (
              <div data-filter={e.district_slug}>
                <Card
                  title={e.name}
                  description={e.short_description}
                  image={e.hero_image}
                  date={formatDate(e.date)}
                  tag={e.district_name}
                />
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<script>
  import { initClientFilter } from "@/lib/utils/filter";

  const filter = initClientFilter({
    filterAttribute: "filter",
    paramName: "district",
  });

  filter.update();
  document.addEventListener("astro:page-load", filter.update);
</script>
