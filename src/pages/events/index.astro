---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";

const allEvents = (await getCollection("events")).sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);

const districts = await getCollection("districts");
const districtFilters = districts
  .sort((a, b) => a.data.order - b.data.order)
  .map((d) => ({ label: d.data.name, value: d.data.slug }));

const selectedDistrict = Astro.url.searchParams.get("district") || "all";
const filteredEvents =
  selectedDistrict === "all"
    ? allEvents
    : allEvents.filter((e) => e.data.district === selectedDistrict);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-PH", {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}

const upcoming = filteredEvents.filter(
  (e) => new Date(e.data.date) >= new Date()
);
const past = filteredEvents.filter(
  (e) => new Date(e.data.date) < new Date()
);
---

<Layout title="Events | Iloilo Province Tourism">
  <Header />

  <main class="page-main container">
    <SectionHeader
      label="Iloilo Events"
      title="What's on"
      subtitle="From grand festivals to intimate cultural tours — something's always happening in Iloilo."
    />

    <FilterTabs
      filters={districtFilters}
      activeFilter={selectedDistrict}
      paramName="district"
    />

    {
      upcoming.length > 0 ? (
        <div class="events-grid">
          {upcoming.map((e) => (
            <div id={e.slug} class="event-item">
              <Card
                title={e.data.title}
                description={e.data.description}
                image={e.data.image}
                date={formatDate(e.data.date)}
                tag={e.data.district}
                size="lg"
              />
              {e.data.venue && (
                <div class="event-meta">
                  <span class="event-venue">📍 {e.data.venue}</span>
                  {e.data.tags?.map((tag) => (
                    <span class="event-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No upcoming events found{selectedDistrict !== "all" ? " for this district" : ""}.</p>
          <a href="/events">View all events</a>
        </div>
      )
    }

    {
      past.length > 0 && (
        <section class="past-events">
          <h2 class="past-events__title">Past Events</h2>
          <div class="events-grid events-grid--past">
            {past.map((e) => (
              <Card
                title={e.data.title}
                description={e.data.description}
                image={e.data.image}
                date={formatDate(e.data.date)}
                tag={e.data.district}
              />
            ))}
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .events-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .events-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .events-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .event-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .event-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
    padding: 0 0.25rem;
  }

  .event-venue {
    font-size: 0.78rem;
    color: var(--color-muted);
    flex: 1;
  }

  .event-tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    background: rgba(196,113,74,0.1);
    color: var(--color-terracotta);
    text-transform: capitalize;
  }

  .past-events {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(26,20,16,0.08);
  }

  .past-events__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .events-grid--past {
    opacity: 0.65;
  }

  .empty-state {
    padding: 4rem;
    text-align: center;
    color: var(--color-muted);
  }

  .empty-state a {
    color: var(--color-terracotta);
    font-weight: 600;
  }
</style>
