---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";
import { formatDate } from "@/lib/utils/date";

const allEvents = (await getCollection("events")).sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);

const districts = await getCollection("districts");
const districtFilters = districts
  .sort((a, b) => a.data.order - b.data.order)
  .map((d) => ({ label: d.data.name, value: d.data.slug }));

const upcoming = allEvents.filter(
  (e) => new Date(e.data.date) >= new Date()
);
const past = allEvents.filter(
  (e) => new Date(e.data.date) < new Date()
);
---

<Layout title="Events | Iloilo Province Tourism">
  <Header />

  <main class="section-container px-4 pb-16 pt-32 md:px-6 lg:px-8">
    <SectionHeader
      label="Iloilo Events"
      title="What's on"
      subtitle="From grand festivals to intimate cultural tours — something's always happening in Iloilo."
    />

    <!-- FilterTabs now purely for UI; the script handles the filtering -->
    <FilterTabs
      filters={districtFilters}
      activeFilter="all"
      paramName="district"
    />

    <!-- UPCOMING SECTION -->
    {
      upcoming.length > 0 ? (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 min-h-[400px]">
          {upcoming.map((e) => (
            <div data-filter={e.data.district}>
              <Card
                title={e.data.title}
                description={e.data.description}
                image={e.data.image}
                date={formatDate(e.data.date)}
                tag={e.data.district}
                size="lg"
              />

              {e.data.venue && (
                <div class="flex flex-wrap items-center gap-2 px-1">
                  <span class="flex-1 text-[0.78rem] text-muted">
                    📍 {e.data.venue}
                  </span>

                  {e.data.tags?.map((tag) => (
                    <span class="rounded-full bg-primary/10 px-2 py-0.5 text-[0.7rem] font-semibold capitalize text-primary">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="py-16 text-center text-muted">
          <p>No upcoming events found.</p>
          <a href="/events" class="font-semibold text-primary">
            View all events
          </a>
        </div>
      )
    }

    <!-- PAST EVENTS SECTION (always rendered, but cards may be hidden by filter) -->
    {
      past.length > 0 && (
        <section class="mt-16 border-t border-deep/8 pt-12">
          <h2 class="mb-6 font-display text-2xl font-normal text-muted">
            Past Events
          </h2>

          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 min-h-[300px] opacity-65">
            {past.map((e) => (
              <div data-filter={e.data.district}>
                <Card
                  title={e.data.title}
                  description={e.data.description}
                  image={e.data.image}
                  date={formatDate(e.data.date)}
                  tag={e.data.district}
                />
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<script>
  import { initClientFilter } from "@/lib/utils/filter";

  const filter = initClientFilter({
    filterAttribute: "filter",
    paramName: "district",
  });

  filter.update();
  document.addEventListener("astro:page-load", filter.update);
</script>
