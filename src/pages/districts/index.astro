---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";

const districts = (await getCollection("districts")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout title="Districts | Iloilo Province Tourism">
  <Header />

  <main class="page-main">
    <div class="container">
      <div class="page-header">
        <SectionHeader
          label="Explore"
          title="Five Districts"
          subtitle="Each corner of Iloilo tells a different story. Choose a district and begin your journey."
          align="center"
        />
      </div>

      <div class="districts-list">
        {
          districts.map((d, i) => (
            <a
              href={`/districts/${d.slug}`}
              class={`district-row ${i % 2 === 1 ? "district-row--reverse" : ""}`}
            >
              <div class="district-row__img-wrap">
                <img
                  src={d.data.heroImage}
                  alt={d.data.name}
                  loading="lazy"
                  class="district-row__img"
                />
              </div>
              <div class="district-row__content">
                <span class="district-row__num">0{i + 1}</span>
                <span class="district-row__tag">{d.data.tagline}</span>
                <h2 class="district-row__name">{d.data.name}</h2>
                <p class="district-row__desc">{d.data.description}</p>
                <span class="district-row__cta">Discover {d.data.name} →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .districts-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .district-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    border-radius: 1.5rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 4px 24px rgba(26, 20, 16, 0.06);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s;
  }

  .district-row:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(26, 20, 16, 0.12);
  }

  @media (min-width: 768px) {
    .district-row {
      flex-direction: row;
      align-items: stretch;
    }
    .district-row--reverse {
      flex-direction: row-reverse;
    }
  }

  .district-row__img-wrap {
    flex: 1;
    min-height: 280px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .district-row__img-wrap {
      min-height: 360px;
      max-width: 50%;
    }
  }

  .district-row__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .district-row:hover .district-row__img {
    transform: scale(1.05);
  }

  .district-row__content {
    flex: 1;
    padding: 2rem 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
  }

  .district-row__num {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-terracotta);
  }

  .district-row__tag {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .district-row__name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--color-deep);
    line-height: 1.1;
  }

  .district-row__desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 45ch;
    margin-top: 0.5rem;
  }

  .district-row__cta {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-terracotta);
    transition: transform 0.2s;
  }

  .district-row:hover .district-row__cta {
    transform: translateX(6px);
  }
</style>
