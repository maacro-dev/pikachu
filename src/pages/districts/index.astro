---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { SupabaseAPI } from "@/lib/api/Supabase";

const districts = await SupabaseAPI.districts.getAll()
---

<Layout title="Districts | Iloilo Province Tourism">
  <Header />

  <main class="pt-32 pb-16">
    <div class="section-container px-4 md:px-6 lg:px-8">
      <div class="mb-16">
        <SectionHeader
          label="Explore"
          title="Five Districts"
          subtitle="Each corner of Iloilo tells a different story. Choose a district and begin your journey."
        />
      </div>

      <div class="flex flex-col gap-12">
        {
          districts.length ? (
            districts.map((d, i) => (
              <a
                href={`/districts/${d.slug}`}
                class:list={[
                  "group overflow-hidden rounded-3xl border border-white/80 bg-white/55 shadow-[0_4px_24px_rgba(26,20,16,0.06)] transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_16px_48px_rgba(26,20,16,0.12)] md:flex md:items-stretch",
                  i % 2 === 1 && "md:flex-row-reverse",
                ]}
              >
                <div class="min-h-70 flex-1 overflow-hidden md:max-w-1/2 md:min-h-90">
                  <img
                    src={d.hero_image}
                    alt={d.name}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                  />
                </div>

                <div class="flex flex-1 flex-col justify-center gap-2 p-8 pb-10">
                  <span class="text-[0.72rem] font-bold tracking-[0.14em] text-primary">
                    0{i + 1}
                  </span>

                  <span class="text-[0.8rem] text-muted">{d.tagline}</span>

                  <h2 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-normal leading-[1.1] text-deep">
                    {d.name}
                  </h2>

                  <p class="mt-2 max-w-[45ch] text-[0.9rem] leading-[1.7] text-muted">
                    {d.short_description}
                  </p>

                  <span class="mt-3 inline-block text-[0.85rem] font-semibold text-primary transition-transform duration-200 group-hover:translate-x-1">
                    Discover {d.name} →
                  </span>
                </div>
              </a>
            ))
          ) : (
            <p>No districts</p>
          )
        }
      </div>
    </div>
  </main>

  <Footer />
</Layout>
