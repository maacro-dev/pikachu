---

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Card from "../../components/Card.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { formatDate } from "@/lib/utils/date";
import { sanitizeSlug } from "@/lib/utils/string";
import { SupabaseAPI } from "@/lib/api/Supabase";

export async function getStaticPaths() {
  const slugs = await SupabaseAPI.municipalities.getSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/404");
}

const municipality = await SupabaseAPI.municipalities.getBySlug(slug);

if (!municipality) {
  return Astro.redirect("/404");
}

const [attractions, food, festivals, events] = await Promise.all([
  SupabaseAPI.attractions.getAllByMunicipalityId(municipality.municipality_id),
  SupabaseAPI.foods.getAllByMunicipalityId(municipality.municipality_id),
  SupabaseAPI.festivals.getAllByMunicipalityId(municipality.municipality_id),
  SupabaseAPI.events.getAllByMunicipalityId(municipality.municipality_id),
]);
---

<Layout
  title={`${municipality.name} | Iloilo Province Tourism`}
  description={municipality.short_description}
>
  <Header transparent />

  <section class="relative flex h-[70vh] min-h-120 items-end overflow-hidden">
    <img
      src={municipality.hero_image ?? "/images/placeholder.jpg"}
      alt={municipality.name}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div
      class="absolute inset-0 bg-linear-to-t from-deep/85 via-deep/20 to-transparent"
    >
    </div>

    <div
      class="section-container relative z-10 flex flex-col gap-2 pb-12 text-white px-4 md:px-6 lg:px-8"
    >
      <a
        href={`/districts/${municipality.district_slug}`}
        id="back-link"
        class="mb-2 inline-block text-[0.8rem] font-medium text-white/70 transition-colors duration-200 hover:text-white"
      >
        ← Back to {sanitizeSlug(municipality.district_slug)}
      </a>
      <span
        class="text-[0.75rem] font-semibold uppercase tracking-widest text-primary"
      >
        {municipality.district_slug}
      </span>
      <h1
        class="font-display text-[clamp(2.5rem,8vw,6rem)] font-normal leading-none"
      >
        {municipality.name}
      </h1>
    </div>
  </section>

  <main
    class="section-container flex flex-col gap-16 py-16 px-4 md:px-6 lg:px-8 min-h-150"
  >
    {
      municipality.short_description && (
        <section class="prose prose-stone max-w-none text-[1.05rem] leading-[1.8] text-muted">
          <p>{municipality.short_description}</p>
        </section>
      )
    }

    {
      attractions.length > 0 && (
        <section class="flex flex-col">
          <SectionHeader label="Explore" title="Attractions" />
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {attractions.map((a) => (
              <Card
                title={a.name}
                description={a.short_description}
                image={a.hero_image}
                tag={a.tags?.[0]}
              />
            ))}
          </div>
        </section>
      )
    }

    {
      food.length > 0 && (
        <section class="flex flex-col">
          <SectionHeader label="Taste" title="Food & Flavors" />
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {food.map((f) => (
              <Card
                title={f.name}
                description={f.short_description}
                image={f.hero_image}
                tag={f.food_type}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- Festivals -->
    {
      festivals.length > 0 && (
        <section class="flex flex-col">
          <SectionHeader label="Celebrate" title="Festivals" />
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {festivals.map((f) => (
              <Card
                title={f.name}
                description={f.short_description}
                image={f.hero_image}
                date={formatDate(f.date)}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- Events -->
    {
      events.length > 0 && (
        <section class="flex flex-col">
          <SectionHeader label="Events" title="Upcoming" />
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {events.map((e) => (
              <Card
                title={e.name}
                description={e.short_description}
                image={e.hero_image}
                date={formatDate(e.date)}
                tag={e.venue ?? ""}
              />
            ))}
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<script>
  const backLink = document.getElementById("back-link");

  if (backLink instanceof HTMLAnchorElement) {
    backLink.addEventListener("click", (e) => {
      e.preventDefault();

      const referrer = document.referrer;

      if (referrer && referrer.includes(window.location.origin)) {
        history.back();
        return;
      }

      window.location.href = backLink.href;
    });
  }
</script>
