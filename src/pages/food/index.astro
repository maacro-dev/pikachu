---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";

const allFood = await getCollection("food");
const districts = (await getCollection("districts")).sort(
  (a, b) => a.data.order - b.data.order
);
const districtFilters = districts.map((d) => ({
  label: d.data.name,
  value: d.data.slug,
}));
---

<Layout title="Food | Iloilo Province Tourism">
  <Header />

  <main class="section-container px-4 pb-16 pt-32 md:px-6 lg:px-8">
    <SectionHeader
      label="Food Capital of the Philippines"
      title="Taste Iloilo"
      subtitle="Ilonggo cuisine is a living heritage — discover iconic dishes, local delicacies, and beloved restaurants across the province."
    />

    <FilterTabs
      filters={districtFilters}
      activeFilter="all"
      paramName="district"
    />

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 min-h-[400px]">
      {allFood.map((f) => (
        <div data-filter={f.data.district}>
          <Card
            title={f.data.name}
            description={f.data.description}
            image={f.data.image}
            tag={f.data.type}
          />
        </div>
      ))}
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initClientFilter } from "@/lib/utils/filter";

  const filter = initClientFilter({
    filterAttribute: "filter",
    paramName: "district",
  });

  filter.update();
  document.addEventListener("astro:page-load", filter.update);
</script>
