---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";

const allAttractions = await getCollection("attractions");
const districts = (await getCollection("districts")).sort(
  (a, b) => a.data.order - b.data.order
);
const districtFilters = districts.map((d) => ({
  label: d.data.name,
  value: d.data.slug,
}));

const selectedDistrict = Astro.url.searchParams.get("district") || "all";
const filtered =
  selectedDistrict === "all"
    ? allAttractions
    : allAttractions.filter((a) => a.data.district === selectedDistrict);
---

<Layout title="Attractions | Iloilo Province Tourism">
  <Header />

  <main class="page-main container">
    <SectionHeader
      label="Places to See"
      title="Attractions"
      subtitle="Explore heritage churches, river esplanades, island coves, and everything in between."
    />

    <FilterTabs
      filters={districtFilters}
      activeFilter={selectedDistrict}
      paramName="district"
    />

    <div class="attractions-grid">
      {
        filtered.length > 0
          ? filtered.map((a) => (
              <Card
                title={a.data.name}
                description={a.data.description}
                image={a.data.image}
                tag={a.data.tags?.[0]}
              />
            ))
          : (
            <div class="empty-state">
              <p>No attractions found for this district yet.</p>
              <a href="/attractions">View all</a>
            </div>
          )
      }
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .attractions-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .attractions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .attractions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .empty-state {
    grid-column: 1 / -1;
    padding: 4rem;
    text-align: center;
    color: var(--color-muted);
  }

  .empty-state a {
    color: var(--color-terracotta);
    font-weight: 600;
  }
</style>
