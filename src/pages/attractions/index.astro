---
export const prerender = true

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";
import { SupabaseAPI } from "../../lib/api/Supabase";

const [allAttractions, districtFilters] = await Promise.all([
  SupabaseAPI.attractions.getAll(),
  SupabaseAPI.districts.getFilters(),
]);
---

<Layout title="Attractions | Iloilo Province Tourism">
  <Header />

  <main class="section-container px-4 pb-16 pt-32 md:px-6 lg:px-8">
    <SectionHeader
      label="Places to See"
      title="Attractions"
      subtitle="Explore heritage churches, river esplanades, island coves, and everything in between."
    />

    <FilterTabs
      filters={districtFilters}
      activeFilter="all"
      paramName="district"
    />

    <div class="grid min-h-100 grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {allAttractions.map((a) => (
        <div data-filter={a.district_slug}>
          <Card
            title={a.name}
            description={a.short_description}
            image={a.hero_image}
            tag={a.tags?.[0]}
          />
        </div>
      ))}
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initClientFilter } from "@/lib/utils/filter";

  const filter = initClientFilter({
    filterAttribute: "filter",
    paramName: "district",
  });

  filter.update();
  document.addEventListener("astro:page-load", filter.update);
</script>
