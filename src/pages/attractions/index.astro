---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterTabs from "../../components/FilterTabs.astro";
import Card from "../../components/Card.astro";

const allAttractions = await getCollection("attractions");
const districts = (await getCollection("districts")).sort(
  (a, b) => a.data.order - b.data.order,
);

const districtFilters = districts.map((d) => ({
  label: d.data.name,
  value: d.data.slug,
}));
---

<Layout title="Attractions | Iloilo Province Tourism">
  <Header />

  <main class="section-container px-4 pb-16 pt-32 md:px-6 lg:px-8">
    <SectionHeader
      label="Places to See"
      title="Attractions"
      subtitle="Explore heritage churches, river esplanades, island coves, and everything in between."
    />

    <FilterTabs
      filters={districtFilters}
      activeFilter="all"
      paramName="district"
    />

    <div
      class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 min-h-100"
    >
      {
        allAttractions.map((a) => {
          return (
            <div data-filter={a.data.district}>
              <Card
                title={a.data.name}
                description={a.data.description}
                image={a.data.image}
                tag={a.data.tags?.[0]}
              />
            </div>
          );
        })
      }
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initClientFilter } from "@/lib/utils/filter";

  const filter = initClientFilter({
    filterAttribute: "filter",
    paramName: "district",
  });

  filter.update();
  document.addEventListener("astro:page-load", () => {
    filter.update();
  });
</script>
