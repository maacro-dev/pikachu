---
interface Props {
  title: string;
  description: string;
  image: string;
  href?: string;
  tag?: string;
  date?: string;
  size?: "sm" | "md" | "lg";
}

const {
  title,
  description,
  image,
  href,
  tag,
  date,
  size = "md",
} = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag href={href} class={`card card--${size}`}>
  <div class="card__image-wrap">
    <img src={image} alt={title} loading="lazy" class="card__image" />
    {tag && <span class="card__tag">{tag}</span>}
  </div>
  <div class="card__body">
    {date && <time class="card__date">{date}</time>}
    <h3 class="card__title">{title}</h3>
    <p class="card__desc">{description}</p>
    {href && <span class="card__cta">Explore →</span>}
  </div>
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: var(--shadow-card);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.3s ease;
    cursor: pointer;
  }

  a.card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(26, 20, 16, 0.14);
  }

  .card__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .card--sm .card__image-wrap { aspect-ratio: 4/3; }
  .card--md .card__image-wrap { aspect-ratio: 16/10; }
  .card--lg .card__image-wrap { aspect-ratio: 16/9; }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card:hover .card__image {
    transform: scale(1.06);
  }

  .card__tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-terracotta);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .card__date {
    font-size: 0.75rem;
    color: var(--color-terracotta);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .card__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-deep);
    line-height: 1.3;
  }

  .card--lg .card__title {
    font-size: 1.35rem;
  }

  .card__desc {
    font-size: 0.83rem;
    color: var(--color-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__cta {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-terracotta);
    transition: transform 0.2s;
  }

  .card:hover .card__cta {
    transform: translateX(4px);
  }
</style>
