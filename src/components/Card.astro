---
interface Props {
  title: string;
  description?: string;
  image?: string;
  href?: string;
  tag?: string;
  date?: string;
  size?: "sm" | "md" | "lg";
  noAspect?: boolean;
  badge?: string;
}

const {
  title,
  description,
  image,
  href,
  tag,
  date,
  size = "md",
  badge,
  noAspect,
} = Astro.props;

const Tag = href ? "a" : "div";
const aspect =
  size === "sm"
    ? "aspect-[4/3]"
    : size === "lg"
      ? "aspect-[16/9]"
      : "aspect-[16/10]";
---

<Tag
  href={href}
  class={[
    "group flex flex-col overflow-hidden rounded-card border border-white/80 bg-white/60 shadow-card transition-all duration-300 ease-out",
    href &&
      "cursor-pointer hover:-translate-y-1 hover:shadow-[0_20px_48px_rgba(26,20,16,0.14)]",
  ].join(" ")}
>
  {
    image &&
      (!noAspect ? (
        <div class={`relative overflow-hidden ${aspect}`}>
          <img
            src={image}
            alt={title}
            loading="lazy"
            class="h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-105"
          />
          {tag && (
            <span class="absolute left-3 top-3 rounded-full bg-primary px-2 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-white">
              {tag}
            </span>
          )}
        </div>
      ) : (
        <div
          class={`relative w-full overflow-hidden rounded-t-xl ${
            size === "sm" ? "h-48" : size === "lg" ? "h-80" : "h-64"
          }`}
        >
          <img
            src={image}
            alt={title}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
          />
          {tag && (
            <span class="absolute left-3 top-3 rounded-full bg-primary px-2 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-white">
              {tag}
            </span>
          )}
        </div>
      ))
  }

  <div class="flex flex-1 flex-col gap-1 p-5">
    {
      date && (
        <time class="text-[0.75rem] font-semibold tracking-wider text-primary">
          {date}
        </time>
      )
    }

    <h3
      class={[
        "font-display font-bold leading-[1.3] text-deep",
        size === "lg" ? "text-[1.35rem]" : "text-[1.1rem]",
      ].join(" ")}
    >
      {title}
    </h3>

    {
      description && (
        <p class="line-clamp-3 text-[0.83rem] leading-[1.6] text-muted">
          {description}
        </p>
      )
    }

    {
      href && (
        <span class="mt-2 inline-block text-[0.8rem] font-semibold text-primary transition-transform duration-200 group-hover:translate-x-1">
          Explore →
        </span>
      )
    }
  </div>
</Tag>
