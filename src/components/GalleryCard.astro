---
interface Props {
  title: string;
  description?: string;
  image?: string;
  href?: string;
  tag?: string;
  badge?: string;
  featured?: boolean;
}

const {
  title,
  description,
  image,
  href,
  tag,
  badge,
  featured = false,
} = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group relative isolate flex h-105 w-full overflow-hidden bg-neutral-900",
    featured ? "rounded-[36px]" : "rounded-[28px]",
  ]}
>
  {/* Background Image */}
  {
    image && (
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
      />
    )
  }

  {/* Top Tag */}
  {
    tag && (
      <div class="absolute left-4 top-4 z-20">
        <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-white">
          {tag}
        </span>
      </div>
    )
  }

  {/* Optional Badge */}
  {
    badge && (
      <div class="absolute right-4 top-4 z-20">
        <span class="rounded-full bg-primary px-3 py-1 text-xs font-bold text-white shadow-lg">
          {badge}
        </span>
      </div>
    )
  }

  <div class="relative z-20 mt-auto m-3 rounded-3xl p-5 text-white">
    {/* Title */}
    <h3
      class:list={[
        "font-display font-bold leading-[1.05] tracking-tight transition-transform duration-500 group-hover:-translate-y-1",
        featured ? "text-3xl" : "text-2xl",
      ]}
    >
      {title}
    </h3>

    {/* Expanding content */}
    <div
      class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 group-hover:grid-rows-[1fr]"
    >
      <div class="overflow-hidden">
        {
          description && (
            <p class="mt-3 text-sm leading-relaxed text-white/80 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              {description}
            </p>
          )
        }
      </div>
    </div>

    {/* Always visible CTA */}
    {
      href && (
        <div class="mt-4 flex items-center gap-2 text-sm font-semibold text-white">
          Explore →
        </div>
      )
    }
  </div>
</Tag>
