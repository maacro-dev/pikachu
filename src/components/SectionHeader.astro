---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  viewAllHref?: string;
  viewAllLabel?: string;
}

const {
  label,
  title,
  subtitle,
  align = "left",
  viewAllHref,
  viewAllLabel = "View all",
} = Astro.props;
---

<div class={`section-header section-header--${align}`}>
  <div class="section-header__top">
    <div class="section-header__text">
      {label && <span class="section-header__label">{label}</span>}
      <h2 class="section-header__title">{title}</h2>
      {subtitle && <p class="section-header__subtitle">{subtitle}</p>}
    </div>
    {
      viewAllHref && (
        <a href={viewAllHref} class="section-header__link">
          {viewAllLabel}
          <span>→</span>
        </a>
      )
    }
  </div>
</div>

<style>
  .section-header {
    margin-bottom: 2.5rem;
  }

  .section-header--center {
    text-align: center;
  }

  .section-header__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-header--center .section-header__top {
    flex-direction: column;
    align-items: center;
  }

  .section-header__label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    margin-bottom: 0.5rem;
  }

  .section-header__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-deep);
  }

  .section-header__subtitle {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 50ch;
    line-height: 1.65;
  }

  .section-header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-terracotta);
    white-space: nowrap;
    flex-shrink: 0;
    margin-bottom: 0.25rem;
    transition: gap 0.2s;
  }

  .section-header__link:hover {
    gap: 0.7rem;
  }
</style>
