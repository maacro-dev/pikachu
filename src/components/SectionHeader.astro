---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  viewAllHref?: string;
  viewAllLabel?: string;
}

const {
  label,
  title,
  subtitle,
  align = "center",
  viewAllHref,
  viewAllLabel = "View all",
} = Astro.props;
---

<div class:list={["mb-10", align === "center" && "text-center"]}>
  <div
    class:list={[
      "flex items-end justify-between",
      align === "center" && "flex-col items-center",
    ]}
  >
    <div class="mx-auto text-center">
      {label && (
        <span class="mb-2 inline-block text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-primary">
          {label}
        </span>
      )}

      <h2 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-normal leading-[1.1] text-deep">
        {title}
      </h2>

      {subtitle && (
        <p class="mt-3 max-w-[70ch] text-[1rem] leading-[1.65] text-muted">
          {subtitle}
        </p>
      )}
    </div>

    {
      viewAllHref && (
        <a
          href={viewAllHref}
          class="mb-1 inline-flex shrink-0 items-center gap-1 text-[0.85rem] font-semibold whitespace-nowrap text-primary transition-all duration-200 hover:gap-2.5"
        >
          {viewAllLabel}
          <span>→</span>
        </a>
      )
    }
  </div>
</div>
