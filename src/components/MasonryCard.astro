---
interface Props {
  title: string;
  description?: string;
  image?: string;
  href?: string;
  tag?: string;
}

const { title, description, image, href, tag } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class="group flex flex-col overflow-hidden rounded-xl border border-white/80 bg-white/60 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
>
  {image && (
    <div class="relative w-full">
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
      />
      {tag && (
        <span class="absolute left-3 top-3 rounded-full bg-primary px-2 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-white">
          {tag}
        </span>
      )}
    </div>
  )}
  <div class="p-4">
    <h3 class="font-display font-bold text-deep text-base">{title}</h3>
    {description && <p class="mt-1 text-xs text-muted line-clamp-3">{description}</p>}
    {href && (
      <span class="mt-2 inline-block text-xs font-semibold text-primary transition-transform duration-200 group-hover:translate-x-1">
        Explore →
      </span>
    )}
  </div>
</Tag>
