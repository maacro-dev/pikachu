---
const footerLinks = {
  Explore: [
    { label: "Districts", href: "/districts" },
    { label: "Attractions", href: "/attractions" },
    { label: "Events", href: "/events" },
    { label: "Food", href: "/food" },
  ],
  Connect: [
    { label: "Visit Iloilo", href: "#" },
    { label: "Travel Guide", href: "#" },
    { label: "Contact", href: "#" },
  ],
};
---

<footer class="mt-24 bg-deep py-16 text-white/60">
  <div class="container mx-auto px-4 md:px-6 lg:px-8">
    <div class="flex flex-col gap-12">
      <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
        <div>
          <span class="mb-3 block font-body text-2xl font-bold tracking-[0.1em] text-white">
            ILO<em class="not-italic text-primary">ILO</em>
          </span>
          <p class="max-w-[20ch] text-[0.85rem] leading-[1.7]">
            Fun. Foodie. Friendly.<br />
            The heart of Western Visayas.
          </p>
        </div>

        <div class="flex gap-12">
          {Object.entries(footerLinks).map(([group, links]) => (
            <div>
              <h4 class="mb-4 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-white">
                {group}
              </h4>
              <ul class="flex list-none flex-col gap-2.5">
                {links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-[0.85rem] text-white/55 transition-colors duration-200 hover:text-white"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-col items-center gap-1 border-t border-white/10 pt-6 text-center">
        <p class="text-[0.8rem]">
          Made with ♡ by Mel Adry · Rei Calopez · Verna Marie
        </p>
        <p class="text-[0.75rem] opacity-50">
          Under <span class="text-primary/80">Gilbert "Bombette" Marin</span>
        </p>
      </div>
    </div>
  </div>
</footer>
