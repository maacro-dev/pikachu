---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const navItems = [
  // { label: "Home", path: "/" },
  { label: "Districts", path: "/districts" },
  { label: "Attractions", path: "/attractions" },
  { label: "Events", path: "/events" },
  { label: "Food", path: "/food" },
];
---

<header class="fixed top-3 left-3 right-3 z-100 flex flex-col gap-2">
  <div
    class:list={[
      "flex items-center justify-between rounded-full border px-4 py-3 shadow-[0_4px_24px_rgba(26,20,16,0.06)] transition-all duration-300 ease-out md:px-5",
      transparent
        ? "border-transparent bg-transparent shadow-none backdrop-blur-none"
        : "border-white/70 bg-white/55 backdrop-blur-[20px]",
    ]}
  >
    <a href="/" class="flex items-center" aria-label="Iloilo Province Tourism">
      <span class="font-body text-base font-bold tracking-widest text-deep">
        ILO<em class="not-italic text-primary">ILO</em>
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            href={item.path}
            class="relative text-[0.85rem] font-medium tracking-[0.02em] text-deep transition-colors duration-200 hover:text-primary after:absolute after:-bottom-0.5 after:left-0 after:h-[1.5px] after:w-0 after:bg-primary-dark after:transition-all after:duration-300 hover:after:w-full"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <button
      id="menu-toggle"
      class="flex w-8 flex-col gap-1.25 bg-none p-1 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      type="button"
    >
      <span class="block h-[1.5px] origin-center bg-deep transition-all duration-300"></span>
      <span class="block h-[1.5px] origin-center bg-deep transition-all duration-300"></span>
      <span class="block h-[1.5px] origin-center bg-deep transition-all duration-300"></span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    aria-hidden="true"
    class="flex max-h-0 flex-col overflow-hidden rounded-2xl border border-white/80 bg-white/90 opacity-0 backdrop-blur-[20px] transition-[max-height,opacity] duration-300 ease-out md:hidden"
  >
    {
      navItems.map((item, index) => (
        <a
          href={item.path}
          class:list={[
            "px-5 py-3 text-[0.9rem] font-medium text-deep transition-colors duration-200 hover:bg-primary/8 hover:text-primary",
            index !== navItems.length - 1 && "border-b border-deep/6",
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  const first = toggle?.children[0] as HTMLSpanElement | undefined;
  const second = toggle?.children[1] as HTMLSpanElement | undefined;
  const third = toggle?.children[2] as HTMLSpanElement | undefined;

  function setOpen(open: boolean) {
    if (!toggle || !menu || !first || !second || !third) return;

    menu.classList.toggle("max-h-[400px]", open);
    menu.classList.toggle("opacity-100", open);
    menu.classList.toggle("max-h-0", !open);
    menu.classList.toggle("opacity-0", !open);

    toggle.setAttribute("aria-expanded", open ? "true" : "false");
    menu.setAttribute("aria-hidden", open ? "false" : "true");

    first.classList.toggle("translate-y-[6.5px]", open);
    first.classList.toggle("rotate-45", open);

    second.classList.toggle("scale-x-0", open);
    second.classList.toggle("opacity-0", open);

    third.classList.toggle("-translate-y-[6.5px]", open);
    third.classList.toggle("-rotate-45", open);
  }

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("max-h-[400px]") ?? false;
    setOpen(!isOpen);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });
</script>
