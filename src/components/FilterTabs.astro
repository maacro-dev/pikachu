---
interface Props {
  filters: { label: string; value: string }[];
  activeFilter?: string;
  paramName?: string;
}

const { filters, activeFilter = "all", paramName = "district" } = Astro.props;

const allFilters = [{ label: "All", value: "all" }, ...filters];
---

<div class="filter-tabs mb-8 flex flex-wrap gap-2">
  {
    allFilters.map((f) => {
      const isActive = activeFilter === f.value;
      return (
        <button
          type="button"
          data-filter={f.value}
          aria-selected={isActive}
          class="rounded-full border px-4 py-1.5 cursor-pointer text-sm font-medium transition
                 border-black/10 bg-white/50 text-muted
                 hover:bg-white/80 hover:text-deep
                 aria-selected:border-deep aria-selected:bg-deep aria-selected:text-white"
        >
          {f.label}
        </button>
      );
    })
  }
</div>
